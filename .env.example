APP_NAME="Local-First Operations Tracker"
APP_ENV=development
DATABASE_URL=sqlite:///./data/app.sqlite
BACKUP_DIR=./backups
HOST=127.0.0.1
PORT=8000
SECRET_KEY=change-me-before-real-use
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=43200
LOGIN_THROTTLE_MAX_ATTEMPTS=5
LOGIN_THROTTLE_WINDOW_SECONDS=300
PASSWORD_ITERATIONS=260000
BACKUP_SCHEDULER_ENABLED=true
BACKUP_SCHEDULER_INTERVAL_MINUTES=1440
BACKUP_RETENTION_COUNT=50
